# Copy this file to .env and fill in the secrets before running docker compose

# ---------- Database ----------
MYSQL_ROOT_PASSWORD=change-me-root
DB_HOST=mysql
DB_PORT=3306
DB_NAME=petcare
DB_USER=petcare
DB_PASSWORD=change-me-db

# ---------- Spring Boot / Auth ----------
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=change-me-jwt
JWT_EXPIRY_MINUTES=15
REFRESH_EXPIRY_DAYS=30
REMINDER_LEAD_DAYS=7
MAX_UPLOAD_SIZE_MB=8
TIMEZONE=UTC

# ---------- Integrations ----------
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4.1-mini
WECHAT_APP_ID=your-miniapp-id
WECHAT_APP_SECRET=your-miniapp-secret

# ---------- Misc ----------
BACKUP_RETENTION_DAYS=7
